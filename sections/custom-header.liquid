{{- 'custom-header.css' | asset_url | stylesheet_tag -}}
<script src="{{ 'custom-header.js' | asset_url }}" defer="defer"></script>

<!-- Custom Sticky Header Section -->
{% style %}
  #shopify-section-{{ section.id }} {
    /* Dynamic Settings from Shopify Theme Editor */
    --header-padding-desktop-x: {{ section.settings.desktop_padding_x }}px;
    --header-padding-desktop-y: {{ section.settings.desktop_padding_y }}px;
    --header-padding-mobile-x: {{ section.settings.mobile_padding_x }}px;
    --header-padding-mobile-y: {{ section.settings.mobile_padding_y }}px;
    --header-bg-color: {{ section.settings.background_color }};
    --header-button-color: {{ section.settings.button_color }};
    --header-button-hover-color: {{ section.settings.button_hover_color }};
  }
{% endstyle %}

<header class="custom-header" data-section-id="{{ section.id }}">
  <!-- Desktop Layout -->
  <div class="custom-header__desktop">
    <div class="custom-header__container">
      <a href="{{ routes.root_url }}" class="custom-header__brand">
        {{ section.settings.heading }}
      </a>
      
      <p class="custom-header__tagline">
        {{ section.settings.sub_heading }}
      </p>
      
      <a href="{{ section.settings.button_url | default: '#' }}" class="custom-header__cta">
        {{ section.settings.button_label }}
        <span class="custom-header__cta-arrow">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" class="icon icon-arrow" viewBox="0 0 14 10"><path fill="currentColor" fill-rule="evenodd" d="M8.537.808a.5.5 0 0 1 .817-.162l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 1 1-.708-.708L11.793 5.5H1a.5.5 0 0 1 0-1h10.793L8.646 1.354a.5.5 0 0 1-.109-.546" clip-rule="evenodd"/></svg>
        </span>
      </a>
    </div>
  </div>

  <!-- Mobile Layout -->
  <div class="custom-header__mobile">
    <!-- Mobile Header Bar (always visible) -->
    <div class="custom-header__mobile-bar">
      <button class="custom-header__menu-toggle" aria-label="Toggle menu" aria-expanded="false">
        <!-- Hamburger Icon (visible when closed) -->
        <span class="custom-header__hamburger">
          <span></span>
          <span></span>
          <span></span>
        </span>
        <!-- Close Icon (visible when open) -->
        <span class="custom-header__close-x">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" class="icon icon-close" viewBox="0 0 18 17"><path fill="currentColor" d="M.865 15.978a.5.5 0 0 0 .707.707l7.433-7.431 7.579 7.282a.501.501 0 0 0 .846-.37.5.5 0 0 0-.153-.351L9.712 8.546l7.417-7.416a.5.5 0 1 0-.707-.708L8.991 7.853 1.413.573a.5.5 0 1 0-.693.72l7.563 7.268z"/></svg>
        </span>
      </button>
      
      <a href="{{ routes.root_url }}" class="custom-header__mobile-brand">
        {{ section.settings.heading }}
      </a>
      
      <div class="custom-header__spacer"></div>
    </div>

    <!-- Mobile Dropdown Content (slides down when open) -->
    <div class="custom-header__mobile-dropdown">
      <div class="custom-header__mobile-content">
        <p class="custom-header__mobile-tagline">
          {{ section.settings.sub_heading }}
        </p>
        
        <a href="{{ section.settings.button_url | default: '#' }}" class="custom-header__mobile-cta">
          {{ section.settings.button_label }}
          <span class="custom-header__cta-arrow">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" class="icon icon-arrow" viewBox="0 0 14 10"><path fill="currentColor" fill-rule="evenodd" d="M8.537.808a.5.5 0 0 1 .817-.162l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 1 1-.708-.708L11.793 5.5H1a.5.5 0 0 1 0-1h10.793L8.646 1.354a.5.5 0 0 1-.109-.546" clip-rule="evenodd"/></svg>
          </span>
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div class="custom-header__mobile-overlay"></div>

{% schema %}
{
  "name": "Custom Header",
  "class": "section-custom-header",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Header Text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Sub Header Text",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Color",
      "default": "#FFF544"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button Hover Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section Background Color",
      "default": "#F5F5F5"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "desktop_padding_x",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Horizontal Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "desktop_padding_y",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Vertical Padding",
      "default": 16
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "mobile_padding_x",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Horizontal Padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_padding_y",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Vertical Padding",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Custom Header"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}